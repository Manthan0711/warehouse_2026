client/data/warehouse-data.json
Maharashtra_Warehouse_Dataset_50000.csv

# Build artifacts (not needed in Bolt)
dist/
dist-ssr/
*.js.map

# Node modules
node_modules/

# Logs
*.log
logs/

# Lock files (too large, Bolt regenerates)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Git
.git/
.gitattributes

# Documentation (reduce size)
PROFESSIONAL_UI_ENHANCEMENT.md
ML_ALGORITHMS_DOCUMENTATION.md
ENHANCEMENT_SUMMARY.md
AI_RECOMMENDATIONS.md
