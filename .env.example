# ===========================================
# SmartWarehouse Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ===========================================
# SUPABASE CONFIGURATION (Required)
# ===========================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key
# This is safe to expose in client-side code
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Your Supabase service role key (for server-side operations)
# WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-key-here

# ===========================================
# GOOGLE GEMINI AI (Optional - for AI features)
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey

VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Port for the backend server
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# ===========================================
# MINIO / S3 STORAGE (Optional - for file uploads)
# ===========================================
# If using MinIO for local development or S3 for production

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=warehouse-images
MINIO_USE_SSL=false

# Presign server URL for file uploads
VITE_PRESIGN_SERVER_URL=http://localhost:4001

# ===========================================
# OPTIONAL FEATURES
# ===========================================

# Enable debug mode (shows additional console logs)
VITE_DEBUG_MODE=false

# API base URL (default: /api)
VITE_API_BASE_URL=/api

# ===========================================
# FREE LLM APIs (Optional - for AI recommendations)
# ===========================================
# You only need ONE of these APIs - pick the easiest for you!

# ⭐ RECOMMENDED: OpenRouter (Easiest - Sign in with Google!)
# Access to 100+ models including FREE ones
# Get your API key at: https://openrouter.ai/keys
# 1. Go to https://openrouter.ai
# 2. Click "Sign in" → Use Google account
# 3. Go to https://openrouter.ai/keys → Create Key
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# Cloudflare Workers AI (Recommended - Free, fast, global edge)
# Best model: llama-3.3-70b-instruct-fp8-fast (70B params, free!)
# Get your credentials at: https://dash.cloudflare.com/?to=/:account/ai/workers-ai
# 1. Go to Workers AI page
# 2. Click "Use REST API"
# 3. Create API Token and copy Account ID
VITE_CLOUDFLARE_ACCOUNT_ID=your_account_id_here
VITE_CLOUDFLARE_AI_TOKEN=your_api_token_here

# Groq API (Alternative - Free, super fast LLM)
# Get your API key at: https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API (Alternative - Free tier available)
# Get your API key at: https://huggingface.co/settings/tokens
VITE_HUGGINGFACE_API_KEY=your_hf_api_key_here
